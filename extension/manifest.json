{
  "manifest_version": 3,
  "name": "Browser MCP",
  "version": "0.1.0",
  "description": "Governed browser automation over your own authenticated session, for AI agents.",
  "minimum_chrome_version": "116",
  "permissions": [
    "tabs",
    "debugger",
    "scripting",
    "nativeMessaging",
    "tabGroups",
    "windows",
    "storage",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
